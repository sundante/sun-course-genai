# ============================================================
# GenAI Code Labs — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Google Gemini API (used by ADK, LangChain-Gemini, default model) ---
GOOGLE_API_KEY=your_google_api_key_here

# --- Google Cloud / Vertex AI (ADK vertex-ai-real-world examples) ---
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
# Run: gcloud auth application-default login  (no key needed after this)

# --- LangChain real-world example (Tavily web search) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- CrewAI real-world example (SerpAPI web search) ---
SERPAPI_API_KEY=your_serpapi_key_here

# --- LangGraph real-world example ---
# Re-uses GOOGLE_API_KEY above

# --- Optional: LangSmith tracing (recommended for debugging) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=genai-code-labs
